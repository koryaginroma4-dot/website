# Copy this file to .env.local and fill with real values.
# .env.local is gitignored and takes precedence over .env.

###> doctrine/doctrine-bundle ###
# Database credentials (required by docker-compose and the Symfony app).
POSTGRES_USER=change_me_user
POSTGRES_PASSWORD=change_me_strong_password
###< doctrine/doctrine-bundle ###

###> symfony/framework-bundle ###
APP_ENV=prod
APP_SECRET=change_me_generate_with_openssl_rand_hex_32
###< symfony/framework-bundle ###

###> symfony/telegram-notifier ###
# TELEGRAM_DSN=telegram://TOKEN@default?channel=CHAT_ID
###< symfony/telegram-notifier ###
